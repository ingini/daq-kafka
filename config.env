# ============================================================
#  config.env  —  DAQ Kafka-MinIO Pipeline 설정 파일
#  start_cameras.sh 와 docker-compose.yml 에서 공통으로 사용
# ============================================================

# ── 차량 / 장비 식별 ──────────────────────────────────────────
VEHICLE_ID=KOR-1234                  # 차량번호 (MinIO 경로에 포함)
                                     # 예) KOR-1234, VH-0001, TEST-01

# ── 네트워크 ─────────────────────────────────────────────────
KAFKA_HOST=localhost
KAFKA_PORT=29092                     # 호스트 → Kafka (start_cameras.sh용)
KAFKA_INTERNAL_PORT=9092             # 컨테이너 내부 통신용

MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

IMU_SRC_IP=192.168.20.50
IMU_DST_PORT=1111

# ── MinIO 버킷 ────────────────────────────────────────────────
MINIO_BUCKET=DAQ                     # 단일 버킷
# 오브젝트 경로: DAQ/{year}/{month}/{day}/{hour}/{vehicle_id}/{sensor}/{timestamp}.{ext}
# 예) DAQ/2026/04/30/09/KOR-1234/cam0/20260430T091530_1777505277.jpg
#     DAQ/2026/04/30/09/KOR-1234/imu/20260430T091530_1777505277.parquet

# ── 카메라 캡처 설정 ──────────────────────────────────────────
CAP_WIDTH=1920
CAP_HEIGHT=1080
CAP_FPS=20
OUT_WIDTH=640
OUT_HEIGHT=360
JPEG_QUALITY=90
PUBLISH_FPS=1                        # Kafka produce 주기 (fps)

# ── 카메라 디바이스 ───────────────────────────────────────────
CAM0_DEVICE=/dev/video0
CAM1_DEVICE=/dev/video1
CAM2_DEVICE=/dev/video2

# ── Kafka 토픽 ────────────────────────────────────────────────
TOPIC_CAM0=sensor.cam0.jpeg
TOPIC_CAM1=sensor.cam1.jpeg
TOPIC_CAM2=sensor.cam2.jpeg
TOPIC_IMU=sensor.imu
TOPIC_GNSS=sensor.gnss

# ── Kafka 보존 정책 ───────────────────────────────────────────
KAFKA_RETENTION_HOURS=6
KAFKA_RETENTION_BYTES=10737418240    # 10 GB

# ── Consumer 설정 ─────────────────────────────────────────────
CONSUMER_BATCH_SIZE=100
CONSUMER_FLUSH_INTERVAL=5            # seconds

# ── IMU 저장 포맷 ─────────────────────────────────────────────
# json    : 그대로 JSON 저장 (기본, 호환성 최고)
# parquet : 배치로 Parquet 저장 (압축률 높음, 분석 최적)
IMU_STORAGE_FORMAT=parquet
IMU_PARQUET_BATCH=1000               # N개 누적 후 Parquet 1파일로 저장

# ── 로그 설정 ─────────────────────────────────────────────────
LOG_DIR=./logs
LOG_RETENTION_DAYS=3                 # N일 지난 로그 자동 삭제
